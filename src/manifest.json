{
	"manifest_version": 3,
	"name": "Thumo",
	"version": "0.0.0",
	"description": "🎴 Elegant YouTube UI Enhancer",
	"permissions": ["tabs", "scripting"],
	"background": { "service_worker": "background.js" },
	"content_scripts": [{ "matches": ["https://www.youtube.com/*"], "js": ["content.js"] }],
	"web_accessible_resources": [{ "matches": ["https://www.youtube.com/*"], "resources": ["content.css"] }]
}